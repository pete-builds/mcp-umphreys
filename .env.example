# mcp-umphreys: environment configuration
# Copy this file to `.env` and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# Mode toggle
# ---------------------------------------------------------------------------
# STUB_MODE=false → production. Reads the umphreys-vault Postgres (source of
#                   truth) and hits the live ATU v2 API for hot-window shows.
# STUB_MODE=true  → dev/tests. The live ATU hot-window path returns mock data
#                   with no network calls. (The vault path still needs Postgres
#                   unless you also leave VAULT_ENABLED unset in a test.)
STUB_MODE=false

# ---------------------------------------------------------------------------
# ATU upstream (All Things Umphreys v2 — public, keyless)
# ---------------------------------------------------------------------------
ATU_BASE_URL=https://allthings.umphreys.com/api/v2
ATU_ARTIST_ID=1

# ---------------------------------------------------------------------------
# Cache (aiosqlite)
# ---------------------------------------------------------------------------
# Container path. Mount a host volume here to persist the cache across
# restarts. The opaque KV cache stores raw JSON ATU responses keyed by
# (endpoint, params_hash) — it is NOT a vault. The vault is Postgres.
CACHE_DB_PATH=/data/umphreys-cache.db
CACHE_TTL_SECONDS=86400
# Short TTL applied ONLY to live ATU reads of shows inside the hot window (see
# VAULT_HOT_WINDOW_HOURS below). On show night the setlist grows live on ATU,
# so the default 24h TTL would freeze a partial snapshot and make an
# in-progress setlist look "final" to the downstream game's resolver.
HOT_WINDOW_CACHE_TTL_SECONDS=90

# ---------------------------------------------------------------------------
# Per-instance throttle (requests per second) against ATU
# ---------------------------------------------------------------------------
THROTTLE_ATU_RPS=3

# ---------------------------------------------------------------------------
# MCP server settings
# ---------------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=3717

# Logging: structured JSON (production) or human-readable text (local dev).
LOG_LEVEL=INFO
LOG_FORMAT=json

TZ=UTC

# ---------------------------------------------------------------------------
# Vault read path (umphreys-vault Postgres — the source of truth)
# ---------------------------------------------------------------------------
# When VAULT_ENABLED=true (the default), read tools serve from the
# umphreys-vault database. Hot-window shows (newer than VAULT_HOT_WINDOW_HOURS)
# always read live from ATU, no matter what — the vault hydrates from the ETL
# so very recent shows lag the live feed. Health goes "degraded" when the last
# ETL run is older than VAULT_MAX_STALE_HOURS so callers can detect a stuck
# pipeline.
VAULT_ENABLED=true
VAULT_HOT_WINDOW_HOURS=24
VAULT_MAX_STALE_HOURS=36

# Postgres connection. Defaults match the docker-compose network where
# mcp-umphreys joins the umphreys-vault stack and resolves `postgres` by name.
PG_HOST=postgres
PG_PORT=5432
PG_DB=umphreys
PG_USER=umphreys
# Required when VAULT_ENABLED=true. Use the same value as the umphreys-vault
# stack's PG_PASSWORD. Never commit a real password.
PG_PASSWORD=
